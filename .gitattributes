# Normalize line endings
* text=auto

# Python
*.py text eol=lf
*.pyi text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.db binary
